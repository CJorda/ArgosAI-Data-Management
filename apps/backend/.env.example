NODE_ENV=development
PORT=3001
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174
DATABASE_URL=postgres://postgres:postgres@localhost:5432/argosai
# Optional admin/superuser URL used only by db:provision-app-role
DB_ADMIN_URL=
# App role to use in production (must not be superuser and must not have BYPASSRLS)
DB_APP_ROLE=argosai_app
DB_APP_PASSWORD=
# If true, backend startup fails when DATABASE_URL role bypasses RLS
ENFORCE_RLS_SAFE_ROLE=false
NO_POSTGRES=false
DEMO_TENANT_CODE=demo
DEMO_TENANT_NAME=Piscifactoria Demo
DEMO_ADMIN_EMAIL=admin@argosai.local
DEMO_ADMIN_PASSWORD=Admin123!
DEMO_ADMIN_NAME=Administrador Demo
# Optional fallback for demo if tenant is not configured in src/config/tenantFeatures.js
DEMO_FEATURES=*
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MS=5000
CAMERA_DEFAULT_PROTOCOL=webrtc

# Email delivery for reports
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ArgosAI <no-reply@argosai.local>
SMTP_REJECT_UNAUTHORIZED=true

# Optional endpoint for SAIH Ebro data capture (must return JSON)
SAIH_EBRO_API_URL=

# Internet connectivity watchdog + Twilio voice escalation
CONNECTIVITY_WATCHDOG_ENABLED=false
CONNECTIVITY_WATCHDOG_INTERVAL_MS=60000
CONNECTIVITY_WATCHDOG_TIMEOUT_MS=3500
CONNECTIVITY_WATCHDOG_FAILURE_THRESHOLD=3
CONNECTIVITY_WATCHDOG_COOLDOWN_MINUTES=30
CONNECTIVITY_WATCHDOG_TARGETS=1.1.1.1:53,8.8.8.8:53
CONNECTIVITY_WATCHDOG_DEFAULT_MESSAGE=Alerta ArgosAI: se detecta perdida de conectividad a internet en la planta.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_ALERT_TO_NUMBERS=

# Automatic synchronization from sensor health incidents to operational alerts
SENSOR_HEALTH_ALERT_SYNC_SCHEDULER_ENABLED=true
SENSOR_HEALTH_ALERT_SYNC_SCHEDULER_POLL_MS=300000
SENSOR_HEALTH_ALERT_SYNC_WINDOW_HOURS=24
SENSOR_HEALTH_ALERT_SYNC_STALE_MINUTES=35
