{
  "name": "argosai-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "node -e \"console.log('No build step needed for backend')\"",
    "lint": "node -e \"console.log('No lint configured yet')\"",
    "db:bootstrap": "node src/database/bootstrapDb.js",
    "migrate": "node src/database/runMigrations.js",
    "seed": "node src/database/seed.js",
    "setup": "pnpm run db:bootstrap && pnpm run migrate && pnpm run seed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.1"
  }
}
